#The first two instructions compile and run cuBLAS_implementation.cu and the rest of the instructions are used for analyzing the SASS as well as monitering various NCU computer metrics.

nvcc -O3 -arch=sm_75 cuBLAS_implementation.cu -o cuBLAS_implementation -lcublas
./cuBLAS_implementation
  
ncu --set full ./cuBLAS_implementation

ncu --target-processes all --launch-skip 0 --launch-count 1 ./cuBLAS_implementation

cuobjdump --dump-sass --function turing_s1688gemm_fp16_256x128_ldg8_stages_32x1_nn /usr/local/cuda/lib64/libcublasLt.so > cublas_kernel.sass
cuobjdump --dump-sass --function turing_s1688gemm_fp16_256x128_ldg8_stages_32x1_nn /usr/local/cuda/lib64/libcublas.so > cublas_kernel.sass
grep -n "turing_s1688gemm_fp16_256x128_ldg8_stages_32x1_nn" -n cublas_kernel.sass | head
head -n 60 cublas_kernel.sass
grep -E '\bLD(S|L)\b|\bST(S|L)\b' cublas_kernel.sass | wc -l
grep -n "code for sm_75" cublas_kernel.sass | head
sed -n '58285,59450p' cublas_kernel.sass



cuobjdump --dump-sass --function "<turing_s1688gemm_fp16_256x128_ldg8_stages_32x1_nn>" /usr/local/cuda/lib64/libcublas.so > cublas_kernel.sass
cuobjdump --dump-sass --function "<turing_s1688gemm_fp16_256x128_ldg8_stages_32x1_nn>" /usr/local/cuda/lib64/libcublasLt.so > cublasLt_kernel.sass




ls /usr/local/cuda/lib64 | grep cublas
cuobjdump --dump-sass --function "<cuBLAS_implementation.cu>" /usr/local/cuda/lib64/libcublas.so > cublas_kernel.sass

cuobjdump --dump-sass /usr/local/cuda/lib64/libcublas.so > cublas_sass.txt
cuobjdump --dump-sass /usr/local/cuda/lib64/libcublas.so | grep -A 20 "sm_75"
cuobjdump --dump-sass libcublas.so | grep HMMA | wc -l
head -n 200 cublas_sass.txt


cuobjdump --dump-sass cuBLAS_implementation > sass.txt
grep -n "Function : tile_test" -n sass.txt
sed -n '100,100p' sass.txt
./cuBLAS_implementation


ncu --target-processes all \
  --section LaunchStats \
  --section Occupancy \
  --section SpeedOfLight \
  --section WorkloadDistribution \
  ./cuBLAS_implementation

ncu --set full ./cuBLAS_implementation

./cuBLAS_implementation
nvidia-smi --query-gpu=pstate,clocks.sm,clocks.mem,power.draw,utilization.gpu --format=csv -l 1
ncu --launch-count 11000 --print-summary per-kernel ./cuBLAS_implementation
ncu --metrics sm__inst_executed_pipe_tensor.sum ./cuBLAS_implementation
